[Unit]
Description=Rulenix backend
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=rulenix
Group=rulenix
WorkingDirectory=/opt/rulenix/backend
EnvironmentFile=/etc/rulenix/backend.env
ExecStart=/opt/rulenix/backend/rulenix-backend
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/rulenix /var/log/rulenix

[Install]
WantedBy=multi-user.target
