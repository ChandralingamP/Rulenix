APP_ENV=test
HOST=127.0.0.1
PORT=18080
DATABASE_URL=postgres://rulenix_test:CHANGE_ME_TEST_ONLY@localhost:5432/rulenix_test
FRONTEND_ORIGIN=http://localhost:5173
RUST_LOG=rulenix_backend=info

CREDENTIAL_ENCRYPTION_PRIMARY_VERSION=1
CREDENTIAL_ENCRYPTION_KEYS=1:<base64-32-byte-test-key>
OTP_HASH_KEY=<at-least-32-random-test-bytes>
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=5
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT=20
OTP_RATE_LIMIT=20
SENSITIVE_RATE_LIMIT=20
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_BASE_SECONDS=5
LOGIN_LOCKOUT_MAX_SECONDS=300
MAX_REQUEST_BODY_BYTES=65536
TRUSTED_PROXIES=
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="Rulenix Tests" <noreply@example.test>

ANGEL_API_BASE=https://broker-mock.example.test
ANGEL_WS_URL=wss://broker-mock.example.test/stream
CLIENT_PUBLIC_IP=127.0.0.1
CLIENT_LOCAL_IP=127.0.0.1
CLIENT_MAC_ADDRESS=02:00:00:00:00:02
FORCE_DEMO_TRADING=true
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
