APP_ENV=staging
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgres://rulenix_staging:<inject-secret>@staging-db.example.com:5432/rulenix?sslmode=verify-full
FRONTEND_ORIGINS=https://staging.rulenix.example.com
RUST_LOG=rulenix_backend=info,tower_http=info

CREDENTIAL_ENCRYPTION_PRIMARY_VERSION=1
CREDENTIAL_ENCRYPTION_KEYS=1:<inject-base64-32-byte-key>
OTP_HASH_KEY=<inject-at-least-32-random-bytes>
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT=10
OTP_RATE_LIMIT=5
SENSITIVE_RATE_LIMIT=10
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_BASE_SECONDS=30
LOGIN_LOCKOUT_MAX_SECONDS=3600
MAX_REQUEST_BODY_BYTES=65536
TRUSTED_PROXIES=<reverse-proxy-cidrs>
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=24

SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USERNAME=<inject-smtp-username>
SMTP_PASSWORD=<inject-smtp-password>
SMTP_FROM="Rulenix Staging" <alerts@example.com>

ANGEL_API_BASE=https://apiconnect.angelone.in
ANGEL_WS_URL=wss://smartapisocket.angelone.in/smart-stream
CLIENT_PUBLIC_IP=<broker-registered-public-ip>
CLIENT_LOCAL_IP=<broker-registered-local-ip>
CLIENT_MAC_ADDRESS=<broker-registered-mac>
FORCE_DEMO_TRADING=true

ALERT_WEBHOOK_URL=https://alerts.example.com/rulenix-staging
ALERT_EMAIL_TO=ops@example.com
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
