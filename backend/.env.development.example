APP_ENV=development
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgres://rulenix:CHANGE_ME_LOCAL_ONLY@localhost:5432/rulenix
FRONTEND_ORIGIN=http://localhost:5173
RUST_LOG=rulenix_backend=debug,tower_http=info

CREDENTIAL_ENCRYPTION_PRIMARY_VERSION=1
CREDENTIAL_ENCRYPTION_KEYS=1:<base64-32-byte-development-key>
OTP_HASH_KEY=<at-least-32-random-development-bytes>
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT=10
OTP_RATE_LIMIT=5
SENSITIVE_RATE_LIMIT=10
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_BASE_SECONDS=30
LOGIN_LOCKOUT_MAX_SECONDS=3600
MAX_REQUEST_BODY_BYTES=65536
TRUSTED_PROXIES=
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=24

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="Rulenix Development" <noreply@example.test>

ANGEL_API_BASE=https://apiconnect.angelone.in
ANGEL_WS_URL=wss://smartapisocket.angelone.in/smart-stream
CLIENT_PUBLIC_IP=127.0.0.1
CLIENT_LOCAL_IP=127.0.0.1
CLIENT_MAC_ADDRESS=02:00:00:00:00:01
FORCE_DEMO_TRADING=false

ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
